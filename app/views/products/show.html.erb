<% content_for :title, @product.name %>

<div class="max-w-screen-xl mx-auto px-4 sm:px-6 py-8">

  <%# Breadcrumb %>
  <nav class="flex items-center gap-1.5 text-sm text-gray-400 mb-8">
    <%= link_to "Home", root_path, class: "hover:text-primary transition-colors font-medium" %>
    <svg class="w-3.5 h-3.5 text-gray-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
    <% if @product.category.present? %>
      <%= link_to @product.category, products_path(category: @product.category), class: "hover:text-primary transition-colors capitalize" %>
      <svg class="w-3.5 h-3.5 text-gray-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    <% end %>
    <span class="text-gray-700 font-medium truncate max-w-xs"><%= @product.name %></span>
  </nav>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">

    <%# Left: Image Gallery (sticky on desktop) %>
    <div class="lg:sticky lg:top-24 h-fit">
      <% main_image = @product.image.attached? ? @product.image : (@product.images.attached? ? @product.images.first : nil) %>
      <% if main_image %>
        <div class="rounded-2xl overflow-hidden bg-gray-50 border border-gray-100 mb-3">
          <%= image_tag main_image,
              class: "w-full h-auto max-h-[480px] object-contain p-8 cursor-zoom-in clickable-image",
              id: "main-image",
              alt: @product.name %>
        </div>

        <%# Thumbnails %>
        <div class="thumbnails flex gap-2 overflow-x-auto pb-1 scrollbar-hide">
          <% if @product.image.attached? %>
            <div class="flex-none w-20 h-20 rounded-xl overflow-hidden border-2 border-primary cursor-pointer shadow-sm">
              <%= image_tag @product.image, class: "w-full h-full object-contain p-2 clickable-image" %>
            </div>
          <% end %>
          <% if @product.images.attached? %>
            <% @product.images.each do |img| %>
              <div class="flex-none w-20 h-20 rounded-xl overflow-hidden border-2 border-gray-200 hover:border-primary cursor-pointer transition-colors">
                <%= image_tag img, class: "w-full h-full object-contain p-2 clickable-image" %>
              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="rounded-2xl bg-gradient-to-br from-gray-50 to-gray-100 flex items-center justify-center" style="height: 480px;">
          <svg class="w-24 h-24 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
      <% end %>
    </div>

    <%# Right: Product Info %>
    <div class="flex flex-col">

      <%# Badges %>
      <div class="flex flex-wrap gap-2 mb-5">
        <% if @product.new_arrival? %>
          <span class="inline-flex items-center gap-1.5 bg-emerald-100 text-emerald-700 text-xs font-bold px-3 py-1.5 rounded-full">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
            New Arrival
          </span>
        <% end %>
        <% if @product.discounted? %>
          <span class="inline-flex items-center gap-1.5 bg-red-100 text-red-600 text-xs font-bold px-3 py-1.5 rounded-full">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M17.707 9.293a1 1 0 010 1.414l-7 7a1 1 0 01-1.414 0l-7-7A.997.997 0 012 10V5a3 3 0 013-3h5c.256 0 .512.098.707.293l7 7zM5 6a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" /></svg>
            On Sale
          </span>
        <% end %>
        <% if @product.category.present? %>
          <span class="bg-gray-100 text-gray-600 text-xs font-semibold px-3 py-1.5 rounded-full capitalize"><%= @product.category %></span>
        <% end %>
      </div>

      <%# Product name %>
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3 leading-tight"><%= @product.name %></h1>

      <%# Brand %>
      <% if @product.brand.present? %>
        <p class="text-sm text-gray-500 mb-5">
          By <span class="font-semibold text-gray-700"><%= @product.brand %></span>
        </p>
      <% end %>

      <%# Pricing %>
      <div class="flex items-baseline flex-wrap gap-3 mb-7 pb-7 border-b border-gray-100">
        <% if @product.discounted? %>
          <span class="text-4xl font-bold text-red-600"><%= number_to_currency(@product.price) %></span>
          <span class="text-xl text-gray-400 line-through font-medium"><%= number_to_currency(@product.original_price) %></span>
          <span class="inline-flex items-center bg-red-100 text-red-600 text-sm font-bold px-3 py-1 rounded-full">
            Save <%= number_to_currency(@product.original_price - @product.price) %>
          </span>
        <% else %>
          <span class="text-4xl font-bold text-gray-900"><%= number_to_currency(@product.price) %></span>
        <% end %>
      </div>

      <%# Trust badges %>
      <div class="grid grid-cols-2 gap-2.5 mb-7">
        <div class="flex items-center gap-2.5 bg-emerald-50 border border-emerald-100 rounded-xl px-3.5 py-2.5">
          <svg class="w-4 h-4 text-emerald-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-xs font-semibold text-emerald-700">In Stock</span>
        </div>
        <div class="flex items-center gap-2.5 bg-blue-50 border border-blue-100 rounded-xl px-3.5 py-2.5">
          <svg class="w-4 h-4 text-blue-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          <span class="text-xs font-semibold text-blue-700"><%= homepage_section_text("guarantee_label", :label, fallback: "5-Year Guarantee") %></span>
        </div>
        <div class="flex items-center gap-2.5 bg-purple-50 border border-purple-100 rounded-xl px-3.5 py-2.5">
          <svg class="w-4 h-4 text-purple-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
          </svg>
          <span class="text-xs font-semibold text-purple-700">Free Delivery</span>
        </div>
        <div class="flex items-center gap-2.5 bg-orange-50 border border-orange-100 rounded-xl px-3.5 py-2.5">
          <svg class="w-4 h-4 text-orange-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
          <span class="text-xs font-semibold text-orange-700">Easy Returns</span>
        </div>
      </div>

      <% unless admin_signed_in? %>
        <%# Add to Cart %>
        <%= form_with url: add_basket_path, method: :post, class: "mb-7" do |f| %>
          <%= f.hidden_field :product_id, value: @product.id %>
          <div class="flex items-center gap-3 mb-4">
            <label class="text-sm font-semibold text-gray-700">Quantity</label>
            <div class="flex items-center border-2 border-gray-200 rounded-xl overflow-hidden focus-within:border-primary transition-colors">
              <button type="button"
                      onclick="let q=this.nextElementSibling; if(q.value>1) q.value=parseInt(q.value)-1"
                      class="w-11 h-11 flex items-center justify-center text-gray-600 hover:bg-gray-50 transition-colors font-bold text-lg select-none">
                &minus;
              </button>
              <%= f.number_field :quantity, value: 1, min: 1,
                  class: "w-12 h-11 text-center border-none focus:outline-none focus:ring-0 font-semibold text-base bg-transparent" %>
              <button type="button"
                      onclick="let q=this.previousElementSibling; q.value=parseInt(q.value)+1"
                      class="w-11 h-11 flex items-center justify-center text-gray-600 hover:bg-gray-50 transition-colors font-bold text-lg select-none">
                &#43;
              </button>
            </div>
          </div>
          <div class="flex gap-3">
            <%= f.submit "Add to Basket",
                class: "flex-1 bg-primary hover:bg-primary-light active:scale-95 text-white font-bold py-4 rounded-2xl transition-all shadow-sm hover:shadow-primary-light hover:shadow-lg text-sm cursor-pointer" %>
            <%= f.submit "Buy Now", name: "buy_now",
                class: "flex-1 bg-gray-900 hover:bg-gray-800 active:scale-95 text-white font-bold py-4 rounded-2xl transition-all shadow-sm hover:shadow-lg text-sm cursor-pointer" %>
          </div>
        <% end %>
      <% end %>

      <%# Description & Specs accordions %>
      <div class="space-y-3">
        <div class="border border-gray-100 rounded-2xl overflow-hidden">
          <details open class="group">
            <summary class="flex items-center justify-between px-5 py-4 cursor-pointer font-semibold text-gray-800 hover:bg-gray-50 transition-colors select-none list-none">
              <span>Description</span>
              <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform duration-200 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-5 pt-1 text-sm text-gray-600 leading-relaxed border-t border-gray-50 prose prose-sm max-w-none">
              <%= @product.description %>
            </div>
          </details>
        </div>

        <% if @product.brand.present? || @product.dimensions.present? %>
          <div class="border border-gray-100 rounded-2xl overflow-hidden">
            <details class="group">
              <summary class="flex items-center justify-between px-5 py-4 cursor-pointer font-semibold text-gray-800 hover:bg-gray-50 transition-colors select-none list-none">
                <span>Specifications</span>
                <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform duration-200 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="border-t border-gray-50">
                <table class="w-full text-sm">
                  <% if @product.brand.present? %>
                    <tr class="border-b border-gray-50">
                      <th class="text-left px-5 py-3 font-medium text-gray-500 bg-gray-50/50 w-2/5">Brand</th>
                      <td class="px-5 py-3 text-gray-800"><%= @product.brand %></td>
                    </tr>
                  <% end %>
                  <% if @product.dimensions.present? %>
                    <tr>
                      <th class="text-left px-5 py-3 font-medium text-gray-500 bg-gray-50/50 w-2/5">Dimensions</th>
                      <td class="px-5 py-3 text-gray-800"><%= @product.dimensions %></td>
                    </tr>
                  <% end %>
                </table>
              </div>
            </details>
          </div>
        <% end %>

        <div class="border border-gray-100 rounded-2xl overflow-hidden">
          <details class="group">
            <summary class="flex items-center justify-between px-5 py-4 cursor-pointer font-semibold text-gray-800 hover:bg-gray-50 transition-colors select-none list-none">
              <span>Customer Reviews</span>
              <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform duration-200 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 py-5 border-t border-gray-50 text-sm text-gray-500 text-center">
              <svg class="w-10 h-10 text-gray-200 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
              </svg>
              No reviews yet. Be the first to review this product!
            </div>
          </details>
        </div>
      </div>
    </div>
  </div>

  <%# Related Products %>
  <% if @related_products&.any? %>
    <section class="mt-20 pt-10 border-t border-gray-100">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-1 h-7 bg-primary rounded-full"></div>
        <h2 class="text-2xl font-bold text-gray-900">You May Also Like</h2>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        <% @related_products.each do |rel| %>
          <%= render "product", product: rel %>
        <% end %>
      </div>
    </section>
  <% end %>

</div>

<%# Image zoom modal %>
<div id="modal-overlay" class="hidden fixed inset-0 bg-black/80 z-50 cursor-zoom-out backdrop-blur-sm"></div>
<div id="image-modal" class="hidden fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-50 bg-white rounded-2xl p-3 shadow-2xl max-w-[90vw] max-h-[90vh]">
  <img src="" alt="zoomed" class="max-w-full max-h-[80vh] object-contain rounded-xl cursor-zoom-out">
</div>

<script>
  function setupImageModal() {
    var overlay = document.getElementById('modal-overlay');
    var modal = document.getElementById('image-modal');
    var modalImg = modal.querySelector('img');

    function hideModal() {
      overlay.classList.add('hidden');
      modal.classList.add('hidden');
      modalImg.src = '';
    }

    document.querySelectorAll('.clickable-image').forEach(function(img) {
      if (img._zoomHandlerAttached) return;
      img._zoomHandlerAttached = true;
      img.addEventListener('click', function(e) {
        e.preventDefault();
        if (!modal.classList.contains('hidden') && modalImg.src === e.currentTarget.src) {
          hideModal();
        } else {
          modalImg.src = e.currentTarget.src;
          overlay.classList.remove('hidden');
          modal.classList.remove('hidden');
        }
      });
    });

    overlay.addEventListener('click', hideModal);
    modalImg.addEventListener('click', hideModal);
  }

  document.addEventListener('turbo:load', setupImageModal);
  document.addEventListener('DOMContentLoaded', setupImageModal);
</script>
