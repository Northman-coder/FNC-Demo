<div class="max-w-screen-xl mx-auto px-6 py-14">
  <h1 class="text-3xl font-bold mb-6">Brands</h1>
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
    <% @brands.each do |brand| %>
      <%= link_to brand, brand_path(brand), class: "block bg-white p-4 rounded-lg shadow hover:shadow-md text-gray-800 text-center" %>
    <% end %>
  </div>
</div>
