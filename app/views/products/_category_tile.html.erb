<%# partial receives category and big flag %>
<%= link_to products_path(category: category.name, anchor: "products"), class: "group block" do %>
  <% media_class = big ? "aspect-square md:aspect-[16/10]" : "aspect-square" %>
  <div class="w-full <%= media_class %> overflow-hidden rounded-2xl bg-gray-100 shadow-sm border border-gray-200">
    <% if category.image.attached? %>
      <%= image_tag category.image, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-300", alt: category.name, loading: "lazy", decoding: "async" %>
    <% else %>
      <div class="w-full h-full bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center">
        <svg class="w-10 h-10 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
    <% end %>
  </div>

  <% title_class = big ? "text-sm md:text-xl" : "text-sm md:text-base" %>
  <p class="mt-3 text-center font-semibold text-gray-900 group-hover:text-primary transition-colors leading-tight <%= title_class %> line-clamp-2">
    <%= category.name %>
  </p>
  <p class="text-center text-xs text-gray-400">Shop now</p>
<% end %>
