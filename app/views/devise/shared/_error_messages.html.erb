<% if resource.errors.any? %>
  <div class="mb-5 bg-red-50 border border-red-200 rounded-xl p-4" data-turbo-cache="false">
    <div class="flex items-start gap-3">
      <svg class="w-4 h-4 text-red-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd"/>
      </svg>
      <div>
        <p class="text-sm font-semibold text-red-700 mb-1">
          <%= resource.errors.count == 1 ? "1 error prevented this from being saved:" : "#{resource.errors.count} errors prevented this from being saved:" %>
        </p>
        <ul class="text-sm text-red-600 space-y-0.5 list-disc list-inside">
          <% resource.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
<% end %>
