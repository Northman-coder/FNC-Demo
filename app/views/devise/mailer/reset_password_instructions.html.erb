<h2>Reset Your Password</h2>
<p class="lead">Hi <%= @resource.email %>, we received a request to reset the password for your account.</p>

<p style="text-align:center;">
  <%= link_to "Reset My Password", edit_password_url(@resource, reset_password_token: @token), class: "btn" %>
</p>

<hr class="divider">

<p class="lead" style="font-size:13px; color:#9ca3af;">
  This link will expire in <%= Devise.reset_password_within / 3600 %> hours.<br>
  If you didn't request a password reset, you can safely ignore this email — your password won't change.
</p>

<% content_for :email_footer do %>
  <p>For security, this request was received for your account. If you did not request this, please contact us.</p>
<% end %>
