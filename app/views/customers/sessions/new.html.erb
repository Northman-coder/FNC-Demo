<div class="w-full min-h-screen pt-24 pb-12 bg-gray-50">
  <div class="max-w-md w-full mx-auto shadow-lg bg-white rounded-2xl py-10 px-8">
    <h2 class="text-3xl font-bold text-indigo-800 mb-2 text-center">Welcome back</h2>
    <p class="text-gray-500 text-sm text-center mb-8">Log in to your account</p>

    <%= form_for(resource, as: :customer, url: customer_session_path) do |f| %>
      <div class="mb-4">
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 px-3 py-2" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password, autocomplete: "current-password",
            class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 px-3 py-2" %>
      </div>

      <% if Devise.mappings[:customer].rememberable? %>
        <div class="flex items-center gap-2 mb-6">
          <%= f.check_box :remember_me, class: "rounded border-gray-300 text-indigo-600" %>
          <%= f.label :remember_me, class: "text-sm text-gray-600" %>
        </div>
      <% end %>

      <%= f.submit "Log in", class: "w-full bg-indigo-600 hover:bg-indigo-500 text-white font-semibold py-3 rounded-lg cursor-pointer transition text-lg" %>
    <% end %>

    <div class="flex flex-col items-center mt-6 gap-2 text-sm text-gray-600">
      <%= link_to "Don't have an account? Sign up", new_customer_registration_path, class: "text-indigo-600 hover:underline" %>
      <%= link_to "Forgot your password?", new_customer_password_path, class: "text-gray-400 hover:underline" %>
    </div>
  </div>
</div>
