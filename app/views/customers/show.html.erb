<% content_for :title, "My Account" %>

<div class="w-full bg-gray-50 py-10">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6">

    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight">My Account</h1>
        <p class="text-sm text-gray-500 mt-1">View your details and track your orders.</p>
      </div>

      <div class="flex flex-wrap items-center gap-2">
        <%= link_to "Edit details", edit_customer_registration_path,
            class: "inline-flex items-center justify-center gap-2 bg-white hover:bg-gray-50 border border-gray-200 text-gray-800 font-semibold px-4 py-2.5 rounded-full transition-colors text-sm" %>
        <%= link_to "Change password", edit_customer_registration_path(anchor: "password"),
            class: "inline-flex items-center justify-center gap-2 bg-white hover:bg-gray-50 border border-gray-200 text-gray-800 font-semibold px-4 py-2.5 rounded-full transition-colors text-sm" %>
        <%= link_to "Sign out", destroy_customer_session_path,
            data: { turbo_method: :delete },
            class: "inline-flex items-center justify-center gap-2 bg-gray-900 hover:bg-gray-800 text-white font-semibold px-4 py-2.5 rounded-full transition-colors text-sm" %>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

      <section class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-full bg-primary-light text-primary font-bold flex items-center justify-center">
            <%= @customer.first_name.first.upcase %><%= @customer.last_name.first.upcase %>
          </div>
          <div class="min-w-0">
            <p class="text-lg font-bold text-gray-900 truncate"><%= @customer.full_name %></p>
            <p class="text-sm text-gray-500 truncate"><%= @customer.email %></p>
          </div>
        </div>

        <div class="mt-6 space-y-4">
          <div class="border border-gray-100 rounded-2xl p-4">
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2">Contact</p>
            <div class="space-y-1.5 text-sm">
              <% if @customer.phone.present? %>
                <p class="text-gray-700"><span class="text-gray-400">Phone:</span> <%= @customer.phone %></p>
              <% end %>
              <p class="text-gray-700"><span class="text-gray-400">Email:</span> <%= @customer.email %></p>
            </div>
          </div>

          <div class="border border-gray-100 rounded-2xl p-4">
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2">Shipping Address</p>
            <% if [@customer.address, @customer.city, @customer.postal_code, @customer.country].any?(&:present?) %>
              <p class="text-sm text-gray-700 leading-relaxed">
                <%= [@customer.address, @customer.city, @customer.postal_code, @customer.country].compact_blank.join(", ") %>
              </p>
            <% else %>
              <p class="text-sm text-gray-500">No address on file yet.</p>
            <% end %>
          </div>
        </div>
      </section>

      <section class="lg:col-span-2 bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="px-6 py-5 border-b border-gray-50 flex items-center justify-between gap-3">
          <div>
            <h2 class="text-lg font-bold text-gray-900">Orders</h2>
            <p class="text-sm text-gray-500"><%= pluralize(@orders.size, "order") %></p>
          </div>
          <%= link_to "Continue shopping", products_path,
              class: "text-sm font-semibold text-primary hover:underline" %>
        </div>

        <% if @orders.any? %>
          <%# Mobile cards %>
          <div class="md:hidden p-4 space-y-3">
            <% @orders.each do |order| %>
              <% item_count = order.order_items.sum(&:quantity) %>
              <div class="border border-gray-100 rounded-2xl p-4">
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <p class="text-sm font-bold text-gray-900">Order #<%= order.id %></p>
                    <p class="text-xs text-gray-500 mt-0.5">
                      <%= order.created_at.to_date.to_s %> &bull; <%= pluralize(item_count, "item") %>
                    </p>
                  </div>
                  <span class="inline-flex items-center bg-gray-100 text-gray-700 text-xs font-semibold px-3 py-1.5 rounded-full">
                    <%= order.status %>
                  </span>
                </div>
                <div class="mt-3 flex items-center justify-between">
                  <p class="text-sm font-bold text-gray-900"><%= number_to_currency(order.total_price) %></p>
                  <%= link_to "View", order_path(order), class: "text-sm font-semibold text-primary hover:underline" %>
                </div>
              </div>
            <% end %>
          </div>

          <%# Desktop table %>
          <div class="hidden md:block overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-gray-50/50">
                <tr class="text-left">
                  <th class="px-6 py-3 font-semibold text-gray-500">Date</th>
                  <th class="px-6 py-3 font-semibold text-gray-500">Items</th>
                  <th class="px-6 py-3 font-semibold text-gray-500">Total</th>
                  <th class="px-6 py-3 font-semibold text-gray-500">Status</th>
                  <th class="px-6 py-3 font-semibold text-gray-500"></th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-50">
                <% @orders.each do |order| %>
                  <% item_count = order.order_items.sum(&:quantity) %>
                  <tr class="hover:bg-gray-50/50 transition-colors">
                    <td class="px-6 py-4 text-gray-700 whitespace-nowrap"><%= order.created_at.to_date.to_s %></td>
                    <td class="px-6 py-4 text-gray-700 whitespace-nowrap"><%= pluralize(item_count, "item") %></td>
                    <td class="px-6 py-4 font-semibold text-gray-900 whitespace-nowrap"><%= number_to_currency(order.total_price) %></td>
                    <td class="px-6 py-4">
                      <span class="inline-flex items-center bg-gray-100 text-gray-700 text-xs font-semibold px-3 py-1.5 rounded-full">
                        <%= order.status %>
                      </span>
                    </td>
                    <td class="px-6 py-4 text-right whitespace-nowrap">
                      <%= link_to "View", order_path(order), class: "text-primary font-semibold hover:underline" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="p-8">
            <div class="border border-gray-100 rounded-2xl p-6 bg-gray-50/50">
              <p class="text-sm font-semibold text-gray-800">No orders yet</p>
              <p class="text-sm text-gray-500 mt-1">When you place an order, it will show up here.</p>
              <div class="mt-4">
                <%= link_to "Browse products", products_path,
                    class: "inline-flex items-center justify-center bg-primary hover:bg-primary-dark text-white font-bold px-5 py-2.5 rounded-full transition-colors text-sm" %>
              </div>
            </div>
          </div>
        <% end %>
      </section>

    </div>
  </div>
</div>
