<div class="w-full min-h-screen pt-24 pb-12 bg-gray-50">
  <div class="max-w-2xl w-full mx-auto shadow-lg bg-white rounded-2xl py-10 px-8">
    <h2 class="text-3xl font-bold text-indigo-800 mb-2 text-center">Create your account</h2>
    <p class="text-gray-500 text-sm text-center mb-8">Fill in your details to get started</p>

    <%= form_for(resource, as: :customer, url: customer_registration_path) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <%# Personal info %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
        <div>
          <%= f.label :first_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :first_name, autofocus: true, autocomplete: "given-name",
              class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 px-3 py-2" %>
        </div>
        <div>
          <%= f.label :last_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :last_name, autocomplete: "family-name",
              class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 px-3 py-2" %>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, autocomplete: "email",
              class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 px-3 py-2" %>
        </div>
        <div>
          <%= f.label :phone, "Phone number", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.telephone_field :phone, autocomplete: "tel",
              class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 px-3 py-2" %>
        </div>
      </div>

      <%# Address info %>
      <div class="mb-4">
        <%= f.label :address, "Street address", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :address, autocomplete: "street-address",
            class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 px-3 py-2" %>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
        <div>
          <%= f.label :city, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :city, autocomplete: "address-level2",
              class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 px-3 py-2" %>
        </div>
        <div>
          <%= f.label :postal_code, "Postal code", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :postal_code, autocomplete: "postal-code",
              class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 px-3 py-2" %>
        </div>
        <div>
          <%= f.label :country, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :country, autocomplete: "country-name",
              class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 px-3 py-2" %>
        </div>
      </div>

      <%# Password %>
      <div class="mb-4">
        <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <% if @minimum_password_length %>
          <span class="text-xs text-gray-400">(<%= @minimum_password_length %> characters minimum)</span>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password",
            class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 px-3 py-2" %>
      </div>

      <div class="mb-6">
        <%= f.label :password_confirmation, "Confirm password", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
            class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 px-3 py-2" %>
      </div>

      <%= f.submit "Create account", class: "w-full bg-indigo-600 hover:bg-indigo-500 text-white font-semibold py-3 rounded-lg cursor-pointer transition text-lg" %>
    <% end %>

    <div class="flex flex-col items-center mt-6 gap-2 text-sm text-gray-600">
      <%= link_to "Already have an account? Log in", new_customer_session_path, class: "text-indigo-600 hover:underline" %>
    </div>
  </div>
</div>
