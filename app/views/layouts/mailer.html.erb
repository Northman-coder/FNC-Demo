<!DOCTYPE html>
<html lang="en">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background-color: #f3f4f6; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #111827; -webkit-text-size-adjust: 100%; }
    a { color: #4f46e5; text-decoration: none; }
    .wrapper { background-color: #f3f4f6; padding: 40px 16px; }
    .container { max-width: 580px; margin: 0 auto; }
    .header { background-color: #4f46e5; border-radius: 16px 16px 0 0; padding: 24px 40px; text-align: center; }
    .header-title { color: #ffffff; font-size: 18px; font-weight: 800; letter-spacing: -0.3px; }
    .body { background-color: #ffffff; padding: 36px 40px; }
    .footer-block { background-color: #f9fafb; border-radius: 0 0 16px 16px; border-top: 1px solid #f3f4f6; padding: 18px 40px; text-align: center; }
    .footer-block p { color: #9ca3af; font-size: 12px; line-height: 1.7; }
    .footer-block a { color: #6b7280; text-decoration: underline; }
    .btn { display: inline-block; background-color: #4f46e5; color: #ffffff; font-size: 14px; font-weight: 700; padding: 14px 32px; border-radius: 50px; text-decoration: none; margin: 20px 0; }
    hr.divider { border: none; border-top: 1px solid #f3f4f6; margin: 24px 0; }
    h2 { font-size: 22px; font-weight: 800; color: #111827; margin-bottom: 8px; }
    p.lead { font-size: 15px; color: #6b7280; line-height: 1.6; margin-bottom: 12px; }
    .meta-label { font-size: 11px; font-weight: 700; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.08em; }
    .meta-value { font-size: 14px; font-weight: 600; color: #111827; }
    table.items { width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 14px; }
    table.items th { font-size: 11px; font-weight: 700; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.07em; padding: 6px 0; border-bottom: 1px solid #f3f4f6; text-align: left; }
    table.items th.r, table.items td.r { text-align: right; }
    table.items td { color: #374151; padding: 11px 0; border-bottom: 1px solid #f9fafb; vertical-align: top; }
    .product-name { font-weight: 600; color: #111827; }
    .product-brand { font-size: 12px; color: #9ca3af; margin-top: 2px; }
    .totals { margin-top: 16px; }
    .total-row { display: flex; justify-content: space-between; font-size: 14px; color: #6b7280; padding: 5px 0; }
    .total-row.grand { border-top: 1px solid #e5e7eb; padding-top: 10px; margin-top: 6px; font-size: 16px; font-weight: 800; color: #111827; }
    .badge { display: inline-block; padding: 3px 12px; border-radius: 50px; font-size: 12px; font-weight: 700; }
    .badge-pending   { background:#fef3c7; color:#92400e; }
    .badge-paid      { background:#dbeafe; color:#1e40af; }
    .badge-shipped   { background:#e0e7ff; color:#3730a3; }
    .badge-delivered { background:#d1fae5; color:#065f46; }
    .badge-cancelled { background:#f3f4f6; color:#6b7280; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="container">
      <div class="header">
        <div class="header-title"><%= ENV.fetch("STORE_NAME", "Our Store") %></div>
      </div>
      <div class="body">
        <%= yield %>
      </div>
      <div class="footer-block">
        <%= content_for?(:email_footer) ? yield(:email_footer) : "" %>
        <p style="margin-top:6px;">
          <%= ENV.fetch("STORE_NAME", "Our Store") %>
          <% if ENV["STORE_ADDRESS"].present? %>
            &bull; <%= ENV["STORE_ADDRESS"] %>
          <% end %>
        </p>
      </div>
    </div>
  </div>
</body>
</html>
