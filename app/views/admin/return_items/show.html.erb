<div class="min-h-screen bg-gray-100 p-8">
  <div class="max-w-4xl mx-auto bg-white p-8 rounded-lg shadow">
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-2xl font-bold">Return #<%= @return_item.id %></h1>
      <button onclick="window.print()" class="bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2 rounded-lg">Print</button>
    </div>

    <p><strong>Product:</strong> <%= @return_item.product.name %></p>
    <p><strong>Quantity:</strong> <%= @return_item.quantity %></p>
    <p><strong>Reason:</strong> <%= @return_item.reason.presence || "-" %></p>
    <p><strong>Customer:</strong> <%= @return_item.customer.full_name %> (<%= @return_item.customer.email %>)</p>

    <h2 class="text-lg font-semibold mt-6 mb-2">Change Status</h2>
    <%= form_with url: admin_return_item_path(@return_item), method: :patch, local: true do |f| %>
      <%= f.select :status, options_for_select(["pending","approved","rejected"], @return_item.status), {}, class: "rounded border-gray-300" %>
      <%= f.submit "Update", class: "ml-2 bg-green-600 text-white px-3 py-1 rounded" %>
    <% end %>

  </div>
</div>

<style>
@media print {
  body * { visibility: hidden; }
  .print-container, .print-container * { visibility: visible; }
  .print-container { position: absolute; left: 0; top: 0; width: 100%; }
}
</style>
