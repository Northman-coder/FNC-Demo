<div class="w-full max-w-2xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Edit Contact Details</h1>
    <%= link_to "Back to Dashboard", admin_dashboard_path, class: "text-indigo-600 hover:text-indigo-800 font-medium" %>
  </div>

  <div class="bg-white shadow-md rounded-lg p-6">
    <%= form_with(model: @contact_detail, url: admin_contact_detail_path, method: :patch, class: "space-y-6") do |form| %>
      <% if @contact_detail.errors.any? %>
        <div class="bg-red-50 text-red-500 px-4 py-3 rounded-md">
          <h2 class="font-bold mb-1"><%= pluralize(@contact_detail.errors.count, "error") %> prohibited this from being saved:</h2>
          <ul class="list-disc ml-5 text-sm">
            <% @contact_detail.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= form.label :company_name, "Company Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :company_name, class: "w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>

      <div>
        <%= form.label :vat_number, "VAT Number", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :vat_number, class: "w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>

      <div>
        <%= form.label :address, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_area :address, rows: 3, class: "w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>

      <div>
        <%= form.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.email_field :email, class: "w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>

      <div>
        <%= form.label :phone, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :phone, class: "w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>

      <div>
        <%= form.label :hours, "Opening Hours", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :hours, class: "w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>

      <div class="pt-4">
        <%= form.submit "Save Details", class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-4 rounded-md shadow-sm transition duration-150 ease-in-out cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>