<div class="min-h-screen bg-gray-100 p-8">
  <div class="max-w-4xl mx-auto">

    <!-- Header -->
    <div class="flex items-center justify-between mb-10">
      <div>
        <h1 class="text-3xl font-bold text-indigo-800">Admin Dashboard</h1>
        <p class="text-gray-500 text-sm mt-1">Manage your store</p>
      </div>
      <%= link_to "Log Out", destroy_admin_session_path, data: { turbo_method: :delete },
          class: "bg-red-600 hover:bg-red-500 text-white font-semibold px-5 py-2.5 rounded-lg transition text-sm" %>
    </div>

    <!-- Action Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">

      <!-- VAT / Tax Card -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <div class="flex items-start justify-between gap-4 mb-4">
          <div>
            <h2 class="text-lg font-semibold text-gray-800">VAT / Tax</h2>
            <p class="text-sm text-gray-500">Set tax rates for UK, US, Europe and International</p>
          </div>
        </div>

        <%= form_with model: @tax_setting, url: admin_tax_setting_path, method: :patch, local: true do |f| %>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <%= f.label :uk_percent, "UK (%)", class: "block text-xs font-semibold text-gray-600 mb-1" %>
              <%= f.number_field :uk_percent, step: 0.01, min: 0, max: 100,
                  class: "w-full rounded-lg border border-gray-200 bg-gray-50 focus:bg-white focus:border-indigo-400 focus:ring-0 text-sm px-3 py-2" %>
            </div>
            <div>
              <%= f.label :us_percent, "US (%)", class: "block text-xs font-semibold text-gray-600 mb-1" %>
              <%= f.number_field :us_percent, step: 0.01, min: 0, max: 100,
                  class: "w-full rounded-lg border border-gray-200 bg-gray-50 focus:bg-white focus:border-indigo-400 focus:ring-0 text-sm px-3 py-2" %>
            </div>
            <div>
              <%= f.label :europe_percent, "Europe (%)", class: "block text-xs font-semibold text-gray-600 mb-1" %>
              <%= f.number_field :europe_percent, step: 0.01, min: 0, max: 100,
                  class: "w-full rounded-lg border border-gray-200 bg-gray-50 focus:bg-white focus:border-indigo-400 focus:ring-0 text-sm px-3 py-2" %>
            </div>
            <div>
              <%= f.label :international_percent, "International (%)", class: "block text-xs font-semibold text-gray-600 mb-1" %>
              <%= f.number_field :international_percent, step: 0.01, min: 0, max: 100,
                  class: "w-full rounded-lg border border-gray-200 bg-gray-50 focus:bg-white focus:border-indigo-400 focus:ring-0 text-sm px-3 py-2" %>
            </div>
          </div>

          <p class="text-xs text-gray-400 mt-3">Applied to new orders based on the customer country.</p>

          <div class="mt-4">
            <%= f.submit "Save VAT settings",
                class: "w-full bg-gray-900 hover:bg-gray-800 text-white font-semibold py-2.5 rounded-lg transition text-sm" %>
          </div>
        <% end %>
      </div>

      <!-- Products Card -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <div class="flex items-center gap-4 mb-4">
          <div class="bg-blue-100 rounded-xl p-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
            </svg>
          </div>
          <div>
            <h2 class="text-lg font-semibold text-gray-800">Products</h2>
            <p class="text-sm text-gray-500">Add and manage products</p>
          </div>
        </div>
        <div class="flex gap-3">
          <%= link_to "Add New Product", new_product_path,
              class: "flex-1 text-center bg-blue-600 hover:bg-blue-500 text-white font-medium py-2 rounded-lg transition text-sm" %>
          <%= link_to "View All", products_path,
              class: "flex-1 text-center bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-2 rounded-lg transition text-sm" %>
        </div>
      </div>

      <!-- Categories Card -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <div class="flex items-center gap-4 mb-4">
          <div class="bg-indigo-100 rounded-xl p-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z" />
            </svg>
          </div>
          <div>
            <h2 class="text-lg font-semibold text-gray-800">Categories</h2>
            <p class="text-sm text-gray-500">Organise product categories</p>
          </div>
        </div>
        <div class="flex gap-3">
          <%= link_to "Manage Categories", categories_path,
              class: "flex-1 text-center bg-indigo-600 hover:bg-indigo-500 text-white font-medium py-2 rounded-lg transition text-sm" %>
          <%= link_to "Add Category", new_category_path,
              class: "flex-1 text-center bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-2 rounded-lg transition text-sm" %>
        </div>
      </div>

      <!-- Inbox Card -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <div class="flex items-center gap-4 mb-4">
          <div class="bg-purple-100 rounded-xl p-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
          </div>
          <div>
            <div class="flex items-center gap-2">
              <h2 class="text-lg font-semibold text-gray-800">Inbox</h2>
              <% if @unread_messages_count.to_i > 0 %>
                <span class="inline-flex items-center justify-center min-w-5 h-5 px-1.5 text-xs font-bold bg-red-600 text-white rounded-full">
                  <%= @unread_messages_count %>
                </span>
              <% end %>
            </div>
            <p class="text-sm text-gray-500">Read customer messages</p>
          </div>
        </div>
        <div class="flex gap-3">
          <%= link_to "View Messages", admin_messages_path,
              class: "flex-1 text-center bg-purple-600 hover:bg-purple-500 text-white font-medium py-2 rounded-lg transition text-sm" %>
        </div>
      </div>

      <!-- Contact Info Card -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <div class="flex items-center gap-4 mb-4">
          <div class="bg-teal-100 rounded-xl p-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
          </div>
          <div>
            <h2 class="text-lg font-semibold text-gray-800">Contact Info</h2>
            <p class="text-sm text-gray-500">Update contact page details</p>
          </div>
        </div>
        <div class="flex gap-3">
          <%= link_to "Edit Details", edit_admin_contact_detail_path,
              class: "flex-1 text-center bg-teal-600 hover:bg-teal-500 text-white font-medium py-2 rounded-lg transition text-sm" %>
        </div>
      </div>

      <!-- Homepage Content Card -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <div class="flex items-center gap-4 mb-4">
          <div class="bg-yellow-100 rounded-xl p-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 7v4a1 1 0 001 1h3m10-5h3a1 1 0 011 1v4m0 6v4a1 1 0 01-1 1h-3m-10-5H4a1 1 0 00-1 1v4" />
            </svg>
          </div>
          <div>
            <h2 class="text-lg font-semibold text-gray-800">Homepage Content</h2>
            <p class="text-sm text-gray-500">Edit promo tiles and hero text</p>
          </div>
        </div>
        <div class="flex flex-col gap-2">
          <%= link_to "New Arrivals tile", edit_admin_homepage_section_path(HomepageSection.find_or_create('new_arrivals')),
              class: "text-left bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-2 px-4 rounded-lg transition text-sm" %>
          <%= link_to "Exclusive Deals tile", edit_admin_homepage_section_path(HomepageSection.find_or_create('exclusive_deals')),
              class: "text-left bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-2 px-4 rounded-lg transition text-sm" %>
          <%= link_to "Catalog stats section", edit_admin_homepage_section_path(HomepageSection.find_or_create('catalog_stats')),
              class: "text-left bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-2 px-4 rounded-lg transition text-sm" %>

          <div class="h-px bg-gray-200 my-1"></div>

          <%= link_to "Free shipping threshold", edit_admin_homepage_section_path(HomepageSection.find_or_create('free_shipping')),
            class: "text-left bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-2 px-4 rounded-lg transition text-sm" %>

          <%= link_to "Guarantee badge text", edit_admin_homepage_section_path(HomepageSection.find_or_create('guarantee_label')),
            class: "text-left bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-2 px-4 rounded-lg transition text-sm" %>

          <%= link_to "Footer description", edit_admin_homepage_section_path(HomepageSection.find_or_create('footer_blurb')),
            class: "text-left bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-2 px-4 rounded-lg transition text-sm" %>
          <%= link_to "Footer trust line", edit_admin_homepage_section_path(HomepageSection.find_or_create('footer_trust_line')),
            class: "text-left bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-2 px-4 rounded-lg transition text-sm" %>
          <%= link_to "Newsletter heading", edit_admin_homepage_section_path(HomepageSection.find_or_create('footer_newsletter_heading')),
            class: "text-left bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-2 px-4 rounded-lg transition text-sm" %>
          <%= link_to "Newsletter subheading", edit_admin_homepage_section_path(HomepageSection.find_or_create('footer_newsletter_subheading')),
            class: "text-left bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-2 px-4 rounded-lg transition text-sm" %>
            <%= link_to "Footer: Privacy label", edit_admin_homepage_section_path(HomepageSection.find_or_create('footer_privacy_label')),
              class: "text-left bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-2 px-4 rounded-lg transition text-sm" %>
            <%= link_to "Footer: Terms label", edit_admin_homepage_section_path(HomepageSection.find_or_create('footer_terms_label')),
              class: "text-left bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-2 px-4 rounded-lg transition text-sm" %>
        </div>
      </div>

      <!-- Customers Card -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <div class="flex items-center gap-4 mb-4">
          <div class="bg-green-100 rounded-xl p-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-3-3h-4m-4 5H3v-2a3 3 0 013-3h4m0-4a3 3 0 11-6 0 3 3 0 016 0zm10 0a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <div class="flex items-center gap-2">
              <h2 class="text-lg font-semibold text-gray-800">Customers</h2>
              <% if @new_customers_count.to_i > 0 %>
                <span class="inline-flex items-center justify-center min-w-5 h-5 px-1.5 text-xs font-bold bg-red-600 text-white rounded-full">
                  <%= @new_customers_count %>
                </span>
              <% end %>
            </div>
            <p class="text-sm text-gray-500">View registered customers</p>
          </div>
        </div>
        <div class="flex gap-3">
          <%= link_to "View All Customers", admin_customers_path,
              class: "flex-1 text-center bg-green-600 hover:bg-green-500 text-white font-medium py-2 rounded-lg transition text-sm" %>
        </div>
      </div>

      <!-- Orders Card -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <div class="flex items-center gap-4 mb-4">
          <div class="bg-blue-100 rounded-xl p-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 7h18M3 12h18M3 17h18" />
            </svg>
          </div>
          <div>
            <div class="flex items-center gap-2">
              <h2 class="text-lg font-semibold text-gray-800">Orders</h2>
              <% if @new_orders_count.to_i > 0 %>
                <span class="inline-flex items-center justify-center min-w-5 h-5 px-1.5 text-xs font-bold bg-red-600 text-white rounded-full">
                  <%= @new_orders_count %>
                </span>
              <% end %>
            </div>
            <p class="text-sm text-gray-500">View customer orders</p>
          </div>
        </div>
        <div class="flex gap-3">
          <%= link_to "View All Orders", admin_orders_path,
              class: "flex-1 text-center bg-blue-600 hover:bg-blue-500 text-white font-medium py-2 rounded-lg transition text-sm" %>
          <%= link_to "Canceled Orders", admin_orders_path(status: "cancelled"),
              class: "flex-1 text-center bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-2 rounded-lg transition text-sm" %>
        </div>
      </div>

      <!-- Sales Card -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <div class="flex items-center gap-4 mb-4">
          <div class="bg-emerald-100 rounded-xl p-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 14l3-3 3 2 5-6" />
            </svg>
          </div>
          <div>
            <h2 class="text-lg font-semibold text-gray-800">Sales</h2>
            <p class="text-sm text-gray-500">Daily & monthly totals</p>
          </div>
        </div>
        <div class="flex gap-3">
          <%= link_to "View Sales", admin_sales_path,
              class: "flex-1 text-center bg-emerald-600 hover:bg-emerald-500 text-white font-medium py-2 rounded-lg transition text-sm" %>
        </div>
      </div>

      <!-- Newsletter Card -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <div class="flex items-center gap-4 mb-4">
          <div class="bg-indigo-100 rounded-xl p-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 20.25c4.97 0 9-3.694 9-8.25s-4.03-8.25-9-8.25S3 7.444 3 12c0 2.104.859 4.023 2.273 5.48.432.447.74 1.04.586 1.641a4.483 4.483 0 01-.923 1.785A5.969 5.969 0 006 21c1.282 0 2.47-.402 3.445-1.087.81.22 1.668.337 2.555.337z" />
            </svg>
          </div>
          <div>
            <h2 class="text-lg font-semibold text-gray-800">Newsletter</h2>
            <p class="text-sm text-gray-500"><%= Subscriber.count %> subscriber<%= "s" if Subscriber.count != 1 %></p>
          </div>
        </div>
        <div class="flex gap-3">
          <%= link_to "Send Newsletter", new_admin_newsletter_path,
              class: "flex-1 text-center bg-indigo-600 hover:bg-indigo-500 text-white font-medium py-2 rounded-lg transition text-sm" %>
        </div>
      </div>

      <!-- Returned Items Card -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
        <div class="flex items-center gap-4 mb-4">
          <div class="bg-red-100 rounded-xl p-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M3 14h18" />
            </svg>
          </div>
          <div>
            <h2 class="text-lg font-semibold text-gray-800">Returns</h2>
            <p class="text-sm text-gray-500">View returned items</p>
          </div>
        </div>
        <div class="flex gap-3">
          <%= link_to "View All Returns", admin_return_items_path,
              class: "flex-1 text-center bg-red-600 hover:bg-red-500 text-white font-medium py-2 rounded-lg transition text-sm" %>
        </div>
      </div>

    </div>
  </div>
</div>
