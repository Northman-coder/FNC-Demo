<% content_for :title, "Contact Us" %>

<div class="w-full">

  <%# Hero %>
  <div class="relative bg-gradient-to-br from-indigo-900 via-indigo-700 to-purple-700 text-white py-24 px-6 text-center overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-10 right-20 w-72 h-72 bg-white rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-10 w-64 h-64 bg-purple-300 rounded-full blur-3xl"></div>
    </div>
    <div class="relative z-10 max-w-2xl mx-auto">
      <span class="inline-flex items-center gap-2 bg-white/15 border border-white/25 text-indigo-200 font-semibold text-xs uppercase tracking-widest px-4 py-1.5 rounded-full mb-6">
        Get in touch
      </span>
      <h1 class="text-5xl md:text-6xl font-bold mb-5 leading-tight">Contact Us</h1>
      <p class="text-indigo-200 text-lg md:text-xl max-w-xl mx-auto leading-relaxed">
        Have a question, a concern, or just want to say hello? We would love to hear from you.
      </p>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-6 py-16 grid md:grid-cols-2 gap-12">

    <%# Contact info from DB %>
    <div>
      <span class="text-xs font-bold text-indigo-600 uppercase tracking-widest">Our Details</span>
      <h2 class="text-2xl font-bold text-gray-900 mt-3 mb-8">How to reach us</h2>
      <div class="flex flex-col gap-5">

        <% if @contact_detail.address.present? %>
          <div class="flex items-start gap-4">
            <div class="bg-indigo-100 text-indigo-600 rounded-2xl p-3.5 flex-shrink-0 shadow-sm">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
            </div>
            <div>
              <p class="font-bold text-gray-800 mb-1">Address</p>
              <p class="text-gray-500 text-sm leading-relaxed whitespace-pre-line"><%= @contact_detail.address %></p>
            </div>
          </div>
        <% end %>

        <% if @contact_detail.email.present? %>
          <div class="flex items-start gap-4">
            <div class="bg-indigo-100 text-indigo-600 rounded-2xl p-3.5 flex-shrink-0 shadow-sm">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
            </div>
            <div>
              <p class="font-bold text-gray-800 mb-1">Email</p>
              <a href="mailto:<%= @contact_detail.email %>" class="text-indigo-600 hover:text-indigo-800 text-sm transition-colors font-medium">
                <%= @contact_detail.email %>
              </a>
            </div>
          </div>
        <% end %>

        <% if @contact_detail.phone.present? %>
          <div class="flex items-start gap-4">
            <div class="bg-indigo-100 text-indigo-600 rounded-2xl p-3.5 flex-shrink-0 shadow-sm">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
            </div>
            <div>
              <p class="font-bold text-gray-800 mb-1">Phone</p>
              <a href="tel:<%= @contact_detail.phone.gsub(/\D/, '') %>" class="text-indigo-600 hover:text-indigo-800 text-sm transition-colors font-medium">
                <%= @contact_detail.phone %>
              </a>
            </div>
          </div>
        <% end %>

        <% if @contact_detail.hours.present? %>
          <div class="flex items-start gap-4">
            <div class="bg-indigo-100 text-indigo-600 rounded-2xl p-3.5 flex-shrink-0 shadow-sm">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <p class="font-bold text-gray-800 mb-1">Business Hours</p>
              <p class="text-gray-500 text-sm leading-relaxed whitespace-pre-line"><%= @contact_detail.hours %></p>
            </div>
          </div>
        <% end %>

      </div>
    </div>

    <%# Contact form %>
    <div>
      <span class="text-xs font-bold text-indigo-600 uppercase tracking-widest">Message Us</span>
      <h2 class="text-2xl font-bold text-gray-900 mt-3 mb-8">Send a message</h2>
      <%= form_with model: @message, url: contact_messages_path, class: "flex flex-col gap-4" do |f| %>
        <% if @message.errors.any? %>
          <div class="bg-red-50 border border-red-200 rounded-2xl px-5 py-4 text-sm text-red-600">
            <% @message.errors.full_messages.each do |err| %>
              <p class="flex items-center gap-1.5"><svg class="w-3.5 h-3.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-5a.75.75 0 01.75.75v4.5a.75.75 0 01-1.5 0v-4.5A.75.75 0 0110 5zm0 10a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" /></svg><%= err %></p>
            <% end %>
          </div>
        <% end %>

        <div>
          <%= f.label :name, "Your Name", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
          <%= f.text_field :name,
              class: "w-full rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:border-indigo-400 focus:ring-0 py-3 px-4 text-sm transition-colors",
              placeholder: "John Doe" %>
        </div>

        <div>
          <%= f.label :email, "Email Address", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
          <%= f.email_field :email,
              class: "w-full rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:border-indigo-400 focus:ring-0 py-3 px-4 text-sm transition-colors",
              placeholder: "you@example.com" %>
        </div>

        <div>
          <%= f.label :subject, "Subject", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
          <%= f.text_field :subject,
              class: "w-full rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:border-indigo-400 focus:ring-0 py-3 px-4 text-sm transition-colors",
              placeholder: "How can we help?" %>
        </div>

        <div>
          <%= f.label :message, "Message", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
          <%= f.text_area :message, rows: 5,
              class: "w-full rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:border-indigo-400 focus:ring-0 py-3 px-4 text-sm resize-none transition-colors",
              placeholder: "Write your message here..." %>
        </div>

        <%= f.submit "Send Message",
            class: "bg-indigo-600 hover:bg-indigo-500 active:scale-95 text-white font-bold py-4 rounded-2xl transition-all shadow-sm hover:shadow-indigo-200 hover:shadow-lg cursor-pointer text-sm" %>
      <% end %>
    </div>

  </div>

</div>
