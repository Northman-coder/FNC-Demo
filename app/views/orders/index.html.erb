<% content_for :title, "My Orders" %>

<div class="max-w-screen-xl mx-auto px-4 sm:px-6 py-10">

  <%# Page header %>
  <div class="flex items-center gap-3 mb-8">
    <div class="w-1 h-8 bg-indigo-600 rounded-full"></div>
    <h1 class="text-3xl font-bold text-gray-900">My Orders</h1>
    <% if @orders.any? %>
      <span class="bg-indigo-100 text-indigo-700 text-sm font-bold px-3 py-1 rounded-full ml-1">
        <%= @orders.size %> <%= @orders.size == 1 ? "order" : "orders" %>
      </span>
    <% end %>
  </div>

  <% if @orders.empty? %>
    <%# Empty state %>
    <div class="text-center py-28">
      <div class="w-24 h-24 bg-gray-100 rounded-3xl flex items-center justify-center mx-auto mb-6">
        <svg class="w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
        </svg>
      </div>
      <h2 class="text-xl font-bold text-gray-800 mb-2">No orders yet</h2>
      <p class="text-gray-400 text-sm mb-8">When you place an order it will appear here.</p>
      <%= link_to "Start Shopping", products_path,
          class: "inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 text-white font-bold px-8 py-3.5 rounded-full transition-colors shadow-sm" %>
    </div>

  <% else %>
    <div class="space-y-4">
      <% @orders.each do |order| %>
        <%
          status_classes = case order.status
          when "pending"   then "bg-amber-100 text-amber-700"
          when "paid"      then "bg-blue-100 text-blue-700"
          when "shipped"   then "bg-indigo-100 text-indigo-700"
          when "delivered" then "bg-emerald-100 text-emerald-700"
          when "cancelled" then "bg-gray-100 text-gray-500"
          else                  "bg-gray-100 text-gray-500"
          end
        %>
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden hover:shadow-md transition-shadow">

          <%# Order card header %>
          <div class="flex flex-wrap items-center justify-between gap-3 px-6 py-4 border-b border-gray-50 bg-gray-50/60">
            <div class="flex items-center gap-3">
              <span class="font-mono font-bold text-gray-800 text-sm"><%= order.order_number %></span>
              <span class="text-gray-300">·</span>
              <span class="text-gray-500 text-sm"><%= order.created_at.strftime("%b %-d, %Y") %></span>
            </div>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold <%= status_classes %>">
              <%= order.status.capitalize %>
            </span>
          </div>

          <%# Product thumbnails + summary %>
          <div class="flex flex-wrap items-center justify-between gap-4 px-6 py-5">
            <%# Thumbnails %>
            <div class="flex items-center gap-2">
              <% order.order_items.first(4).each do |item| %>
                <% cover = item.product.image.attached? ? item.product.image : (item.product.images.attached? ? item.product.images.first : nil) %>
                <div class="w-12 h-12 bg-gray-50 rounded-xl border border-gray-100 overflow-hidden flex-shrink-0">
                  <% if cover %>
                    <%= image_tag cover, class: "w-full h-full object-contain p-1" %>
                  <% else %>
                    <div class="w-full h-full flex items-center justify-center text-gray-300">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                    </div>
                  <% end %>
                </div>
              <% end %>
              <% extra = order.order_items.count - 4 %>
              <% if extra > 0 %>
                <div class="w-12 h-12 bg-gray-100 rounded-xl border border-gray-100 flex items-center justify-center flex-shrink-0">
                  <span class="text-xs font-bold text-gray-400">+<%= extra %></span>
                </div>
              <% end %>
              <span class="text-sm text-gray-400 ml-1">
                <%= order.order_items.sum(:quantity) %> <%= order.order_items.sum(:quantity) == 1 ? "item" : "items" %>
              </span>
            </div>

            <%# Total + actions %>
            <div class="flex items-center gap-4">
              <div class="text-right">
                <p class="text-xs text-gray-400 mb-0.5">Total</p>
                <p class="text-lg font-bold text-gray-900"><%= number_to_currency(order.total_with_tax) %></p>
              </div>
              <div class="flex items-center gap-2">
                <% if order.cancellable_by_customer? %>
                  <%= button_to "Cancel", cancel_order_path(order), method: :patch,
                      class: "px-4 py-2 rounded-xl border border-gray-200 text-sm font-semibold text-gray-500 hover:border-red-300 hover:text-red-500 hover:bg-red-50 transition-all cursor-pointer",
                      data: { turbo_confirm: "Cancel order ##{order.id}?" } %>
                <% end %>
                <% if order.status == "pending" %>
                  <%= link_to "Pay", pay_order_path(order),
                      class: "inline-flex items-center bg-gray-900 hover:bg-gray-800 text-white text-sm font-bold px-4 py-2 rounded-xl transition-colors shadow-sm" %>
                <% end %>
                <%= link_to order_path(order),
                    class: "inline-flex items-center gap-1.5 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-bold px-5 py-2 rounded-xl transition-colors shadow-sm" do %>
                  View Order
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                  </svg>
                <% end %>
              </div>
            </div>
          </div>

        </div>
      <% end %>
    </div>
  <% end %>

</div>
